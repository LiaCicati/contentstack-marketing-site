# ─────────────────────────────────────────────
# Contentstack Credentials
# ─────────────────────────────────────────────
# Find these in Contentstack Dashboard → Settings → Stack
CONTENTSTACK_API_KEY=your_stack_api_key
CONTENTSTACK_DELIVERY_TOKEN=your_delivery_token
CONTENTSTACK_ENVIRONMENT=production

# Optional: specify region (us | eu | azure_na | azure_eu | gcp_na)
CONTENTSTACK_REGION=us

# Optional: branch support
CONTENTSTACK_BRANCH=main

# ─────────────────────────────────────────────
# Live Preview (optional, for editor experience)
# ─────────────────────────────────────────────
CONTENTSTACK_PREVIEW_TOKEN=your_preview_token
CONTENTSTACK_LIVE_PREVIEW=false
