# ─────────────────────────────────────────────
# Contentstack Credentials
# ─────────────────────────────────────────────
# NEXT_PUBLIC_ prefix is required so the Live Preview
# client component can read them at runtime.
NEXT_PUBLIC_CONTENTSTACK_API_KEY=your_stack_api_key
NEXT_PUBLIC_CONTENTSTACK_DELIVERY_TOKEN=your_delivery_token
NEXT_PUBLIC_CONTENTSTACK_ENVIRONMENT=production

# Optional: specify region (us | eu | azure_na | azure_eu)
NEXT_PUBLIC_CONTENTSTACK_REGION=us

# ─────────────────────────────────────────────
# Live Preview
# ─────────────────────────────────────────────
NEXT_PUBLIC_CONTENTSTACK_PREVIEW_TOKEN=your_preview_token
